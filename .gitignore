.venv/
__pycache__/
*.py[cod]
.env
.env.local
# Generated artifacts. Eval *results* are committed deliberately (see
# data/evals/) — they are the evidence behind the README's numbers.
data/corpus/
data/*.jsonl
data/*.json
data/*.txt
# Local server logs. Transient run noise, not evidence — unlike data/evals/.
data/*.err
data/*.out
# …except the packed CAG prefix. It is committed on purpose: the code treats it
# as frozen bytes, and a prefix regenerated per-environment could drift and
# silently break caching. ~550 KB.
!data/cag_context.json
.pytest_cache/
.ruff_cache/
*.egg-info/
dist/
build/
.DS_Store
