# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Gemini (Vertex AI, Express mode) --------------------------------------
# Express-mode key ("AQ."-prefixed). Authenticates with x-goog-api-key against
# aiplatform.googleapis.com/v1beta1/publishers/google/models/{model}:generateContent
GOOGLE_API_KEY=

# --- Azure AI Search -------------------------------------------------------
# Free tier: 50 MB storage, 3 indexes, 1 free service per subscription.
# Semantic ranker is included on free at no extra cost.
AZURE_SEARCH_ENDPOINT=https://<service-name>.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=genai-stack-docs

# --- App -------------------------------------------------------------------
# Hard ceiling on model spend per session, in US cents. The app refuses to
# call the model once a session crosses this. Checked before spending.
SESSION_COST_CAP_CENTS=25
